pipeline {
    agent {
        label 'jenkins-slave'
    }
    
    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Docker image tag to deploy')
        string(name: 'DEPLOY_ENVIRONMENT', defaultValue: 'production', description: 'Deployment environment')
    }
    
    environment {
        DOCKERHUB_USERNAME = 'your-dockerhub-username'
        KUBECONFIG = '/home/jenkins/.kube/config'
        K8S_MANIFESTS_PATH = 'k8s/k3s-demo-ultra'
        NAMESPACE = "${params.DEPLOY_ENVIRONMENT}"
    }
    
    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
                sh 'git log --oneline -1'
            }
        }
        
        stage('Configure kubectl') {
            steps {
                script {
                    echo "Configuring kubectl for k3s cluster..."
                    sh """
                        kubectl version --client
                        kubectl get nodes
                    """
                }
            }
        }
        
        stage('Create Namespace') {
            steps {
                script {
                    echo "Creating namespace: ${NAMESPACE}..."
                    sh """
                        kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -
                    """
                }
            }
        }
        
        stage('Update Image Tags') {
            steps {
                script {
                    echo "Updating image tags in manifests..."
                    sh """
                        cd ${K8S_MANIFESTS_PATH}
                        sed -i 's|your-dockerhub-username|${DOCKERHUB_USERNAME}|g' *.yaml
                        sed -i 's|:latest|:${params.IMAGE_TAG}|g' deployment-*.yaml
                        cd ../..
                    """
                }
            }
        }
        
        stage('Apply ConfigMaps and Secrets') {
            steps {
                script {
                    echo "Applying ConfigMaps and Secrets..."
                    sh """
                        kubectl apply -f ${K8S_MANIFESTS_PATH}/configmap-*.yaml -n ${NAMESPACE}
                        kubectl apply -f ${K8S_MANIFESTS_PATH}/secret-*.yaml -n ${NAMESPACE}
                    """
                }
            }
        }
        
        stage('Deploy PostgreSQL') {
            steps {
                script {
                    echo "Deploying PostgreSQL..."
                    sh """
                        kubectl apply -f ${K8S_MANIFESTS_PATH}/statefulset-postgres.yaml -n ${NAMESPACE}
                        kubectl rollout status statefulset/postgres -n ${NAMESPACE} --timeout=300s
                    """
                }
            }
        }
        
        stage('Deploy Backend Services') {
            steps {
                script {
                    echo "Deploying backend services..."
                    sh """
                        kubectl apply -f ${K8S_MANIFESTS_PATH}/deployment-product-service.yaml -n ${NAMESPACE}
                        kubectl apply -f ${K8S_MANIFESTS_PATH}/deployment-order-service.yaml -n ${NAMESPACE}
                        kubectl apply -f ${K8S_MANIFESTS_PATH}/deployment-user-service.yaml -n ${NAMESPACE}
                        kubectl apply -f ${K8S_MANIFESTS_PATH}/deployment-api-gateway.yaml -n ${NAMESPACE}
                    """
                }
            }
        }
        
        stage('Wait for Backend Services') {
            steps {
                script {
                    echo "Waiting for backend services to be ready..."
                    sh """
                        kubectl rollout status deployment/product-service -n ${NAMESPACE} --timeout=60s
                        kubectl rollout status deployment/order-service -n ${NAMESPACE} --timeout=60s
                        kubectl rollout status deployment/user-service -n ${NAMESPACE} --timeout=60s
                        kubectl rollout status deployment/api-gateway -n ${NAMESPACE} --timeout=60s
                    """
                }
            }
        }
        
        stage('Deploy Frontend') {
            steps {
                script {
                    echo "Deploying frontend..."
                    sh """
                        kubectl apply -f ${K8S_MANIFESTS_PATH}/deployment-frontend.yaml -n ${NAMESPACE}
                        kubectl rollout status deployment/frontend -n ${NAMESPACE} --timeout=60s
                    """
                }
            }
        }
        
        stage('Apply Ingress') {
            steps {
                script {
                    echo "Applying Traefik ingress..."
                    sh """
                        kubectl apply -f ${K8S_MANIFESTS_PATH}/ingress.yaml -n ${NAMESPACE}
                    """
                }
            }
        }
        
        stage('Verify Deployment') {
            steps {
                script {
                    echo "Verifying deployment..."
                    sh """
                        kubectl get pods -n ${NAMESPACE} -o wide
                        kubectl get services -n ${NAMESPACE}
                        kubectl get ingress -n ${NAMESPACE}
                    """
                }
            }
        }
        
        stage('Smoke Tests') {
            steps {
                script {
                    echo "Running smoke tests..."
                    sh """
                        # Get node IP
                        NODE_IP=\$(kubectl get nodes -o jsonpath='{.items[0].status.addresses[0].address}')
                        
                        # Test health endpoints
                        sleep 10
                        curl -f http://\$NODE_IP/api/products || echo "Products endpoint check failed"
                        curl -f http://\$NODE_IP/ || echo "Frontend check failed"
                    """
                }
            }
        }
    }
    
    post {
        always {
            cleanWs()
        }
        success {
            echo 'CD Pipeline completed successfully!'
            echo "Deployment to ${NAMESPACE} completed with image tag: ${params.IMAGE_TAG}"
        }
        failure {
            echo 'CD Pipeline failed!'
            sh 'kubectl describe pods -n ${NAMESPACE} || true'
        }
    }
}
