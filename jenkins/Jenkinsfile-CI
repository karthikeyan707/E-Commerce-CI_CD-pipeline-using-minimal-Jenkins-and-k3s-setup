pipeline {
    agent {
        label 'jenkins-slave'
    }
    
    triggers {
        githubPush()
    }
    
    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')
        SONARQUBE_TOKEN = credentials('sonarqube-token')
        NEXUS_URL = 'http://nexus:8081'
        NEXUS_CREDENTIALS = credentials('nexus-credentials')
        DOCKERHUB_USERNAME = 'ukarthikeyan'
        SERVICES = 'api-gateway product-service order-service user-service frontend'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
    }
    
    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
                sh 'git log --oneline -1'
            }
        }
        
        stage('Build') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        dir(service) {
                            echo "Building ${service}..."
                            sh 'npm ci'
                        }
                    }
                }
            }
        }
        
        stage('Unit Tests') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        dir(service) {
                            echo "Testing ${service}..."
                            sh 'npm test'
                        }
                    }
                }
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        dir(service) {
                            withSonarQubeEnv('SonarQube') {
                                sh """
                                    npx sonar-scanner \
                                    -Dsonar.projectKey=ecommerce-${service} \
                                    -Dsonar.projectName="E-Commerce ${service}" \
                                    -Dsonar.sources=src \
                                    -Dsonar.tests=tests \
                                    -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                                """
                            }
                        }
                    }
                }
            }
        }
        
        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }
        
        stage('Docker Build') {
            steps {
                script {
                    echo "Building all Docker images using docker-compose..."
                    sh """
                        cd docker
                        IMAGE_TAG=${IMAGE_TAG} DOCKERHUB_USERNAME=${DOCKERHUB_USERNAME} docker-compose -f docker-compose.build.yml build
                    """
                    
                    echo "Docker images built successfully:"
                    sh "docker images | grep ${DOCKERHUB_USERNAME} || true"
                }
            }
        }
        
        stage('Trivy Scan') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        echo "Scanning ${service} with Trivy..."
                        sh """
                            trivy image --severity HIGH,CRITICAL --exit-code 1 ${DOCKERHUB_USERNAME}/${service}:${IMAGE_TAG}
                        """
                    }
                }
            }
        }
        
        stage('Push to DockerHub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                        
                        SERVICES.split(' ').each { service ->
                            echo "Pushing ${service} to DockerHub..."
                            sh """
                                docker push ${DOCKERHUB_USERNAME}/${service}:${IMAGE_TAG}
                                docker push ${DOCKERHUB_USERNAME}/${service}:latest
                            """
                        }
                    }
                }
            }
        }
        
        stage('Upload Artifacts to Nexus') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        dir(service) {
                            echo "Uploading ${service} artifacts to Nexus..."
                            sh """
                                tar -czf ${service}-${IMAGE_TAG}.tar.gz src package.json package-lock.json || true
                                curl -u ${NEXUS_CREDENTIALS} --upload-file ${service}-${IMAGE_TAG}.tar.gz \
                                    ${NEXUS_URL}/repository/ecommerce-artifacts/${service}/${IMAGE_TAG}/ || true
                            """
                        }
                    }
                }
            }
        }
        
        stage('Manual Approval for CD') {
            steps {
                script {
                    def userInput = input(
                        id: 'deployApproval',
                        message: 'CI Pipeline Successful. Deploy to k3s cluster?',
                        parameters: [
                            choice(
                                name: 'DEPLOY_ENVIRONMENT',
                                choices: ['production', 'staging'],
                                description: 'Select deployment environment'
                            ),
                            text(
                                name: 'DEPLOY_NOTES',
                                description: 'Deployment notes (optional)',
                                defaultValue: "Build ${env.BUILD_NUMBER} - ${IMAGE_TAG}"
                            )
                        ],
                        submitterParameter: 'APPROVER'
                    )
                    echo "Deployment approved by: ${userInput.APPROVER}"
                    echo "Deploying to: ${userInput.DEPLOY_ENVIRONMENT}"
                    echo "Notes: ${userInput.DEPLOY_NOTES}"
                    env.DEPLOY_ENV = userInput.DEPLOY_ENVIRONMENT
                }
            }
        }
        
        stage('Trigger CD Pipeline') {
            steps {
                script {
                    echo "Triggering CD Pipeline for environment: ${env.DEPLOY_ENV}"
                    build(
                        job: 'ecommerce-cd',
                        parameters: [
                            string(name: 'IMAGE_TAG', value: "${IMAGE_TAG}"),
                            string(name: 'DEPLOY_ENVIRONMENT', value: "${env.DEPLOY_ENV}")
                        ],
                        wait: false
                    )
                }
            }
        }
    }
    
    post {
        always {
            sh 'docker logout || true'
            cleanWs()
        }
        success {
            echo 'CI Pipeline completed successfully!'
        }
        failure {
            echo 'CI Pipeline failed!'
        }
    }
}
